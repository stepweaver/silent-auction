# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Basic Auth for Admin
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=some-strong-pass

# Auction Settings (optional - can also be set in admin)
NEXT_PUBLIC_CONTACT_EMAIL=pto@example.org
PAYMENT_INSTRUCTIONS="Please complete your payment online..."
PICKUP_INSTRUCTIONS="Items may be picked up on Thursday..."
PICKUP_CONTACT="Stephanie (586) 322-5097"
NEXT_PUBLIC_PICKUP_CONTACT="Stephanie (586) 322-5097"

# Online payment links
CHEDDARUP_PAYMENT_URL_WINNERS=https://my.cheddarup.com/c/...
CHEDDARUP_PAYMENT_URL_DONATIONS=https://my.cheddarup.com/c/...
NEXT_PUBLIC_CHEDDARUP_PAYMENT_URL_WINNERS=https://my.cheddarup.com/c/...

# Notification Settings
NEXT_PUBLIC_SITE_URL=https://your-auction-site.com
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAILS=admin1@example.org,admin2@example.org

# Security Secrets (REQUIRED for production - at least 32 characters each)
VERIFICATION_SECRET=your-strong-random-secret-for-email-verification
ENROLLMENT_SECRET=your-strong-random-secret-for-vendor-enrollment
JWT_SECRET=your-strong-random-secret-for-jwt-sessions
CSRF_SECRET=your-strong-random-secret-for-csrf-protection

# Cron (optional - for close-check endpoint)
AUCTION_CRON_SECRET=your-cron-secret

# Demo mode (portfolio showcase). Set both to "true" for demo, "false" for real auction.
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
# Optional: separate secret for demo reset cron (falls back to AUCTION_CRON_SECRET)
# DEMO_RESET_SECRET=your-demo-reset-secret
